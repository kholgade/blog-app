---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Blog — be-astute.in" description="All blog posts">
  <div class="mb-16 sm:mb-24">
    <h1 class="text-2xl font-serif font-bold mb-12 sm:text-3xl">Blog</h1>

    {
      sortedPosts.length > 0 ? (
        sortedPosts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="flex justify-between items-start gap-8 group mb-10 sm:mb-12 no-underline">
            <div class="grow">
              <h2 class="text-xl leading-tight font-serif font-medium group-hover:underline group-hover:decoration-dashed group-hover:underline-offset-4 group-hover:decoration-1 sm:text-2xl text-[var(--color-main-text)]">
                {post.data.title}
              </h2>
              <div class="mt-1 text-sm leading-normal text-[var(--color-muted)]">
                <time datetime={post.data.date.toISOString()}>
                  {new Date(post.data.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                </time>
              </div>
              {post.data.description && (
                <div class="mt-3 text-sm leading-normal font-serif text-[var(--color-muted)]">
                  {post.data.description}
                </div>
              )}
            </div>
            <div class="hidden font-serif italic opacity-0 transition group-hover:opacity-100 sm:inline-flex sm:gap-1 sm:items-center sm:shrink-0 text-[var(--color-main-text)]">
              Read
            </div>
          </a>
        ))
      ) : (
        <p class="font-serif text-[var(--color-muted)]">No posts yet. Check back soon.</p>
      )
    }
  </div>
</Base>
