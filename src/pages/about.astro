---
import Base from "../layouts/Base.astro";
---

<Base title="About — be-astute.in" description="About be-astute.in">
  <div class="mb-16 sm:mb-24">
    <h1 class="text-2xl font-serif font-bold mb-8 sm:text-3xl">About</h1>

    <div class="prose font-serif text-[var(--color-main-text)]">
      <p>
        Welcome to be-astute.in. This is a space for sharing thoughts, insights, and ideas about technology, 
        entrepreneurship, and building things that matter.
      </p>
      <p>
        The name reflects a commitment to sharp, perceptive thinking — cutting through noise to focus 
        on what actually matters.
      </p>
    </div>
  </div>
</Base>
